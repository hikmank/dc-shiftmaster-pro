# DC-ShiftMaster Pro — Environment Configuration
# Copy this file to .env and adjust values for your deployment.

# Flask session signing key. Set a strong random value for production.
# If not set, a random key is generated on each restart (sessions won't persist).
SECRET_KEY=change-me-to-a-random-string

# Host and port for Gunicorn / Flask to bind to.
SHIFTMASTER_HOST=0.0.0.0
SHIFTMASTER_PORT=5000

# Path to the SQLite database file.
SHIFTMASTER_DB_PATH=/data/teammates.db

# Shared team password used for legacy authentication.
SHIFTMASTER_PASSWORD=shiftmaster

# Gunicorn worker count (default: 2 × CPU cores + 1).
# GUNICORN_WORKERS=5

# Gunicorn log level (debug, info, warning, error, critical).
# GUNICORN_LOG_LEVEL=info

# --- Email Notifications (AWS SES) ---

# AWS SES sender email address (e.g. noreply@example.com).
# If not set, email notifications are disabled.
SES_SENDER_EMAIL=

# AWS region for SES (default: us-east-1).
SES_AWS_REGION=us-east-1
